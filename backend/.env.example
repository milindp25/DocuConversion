# DocuConversion Backend — Environment Variables
# Copy this file to .env and fill in real values for local development.
# Never commit .env to source control.

# -------------------------------------------------------------------------
# Application
# -------------------------------------------------------------------------
ENVIRONMENT=development

# -------------------------------------------------------------------------
# CORS — comma-separated list of allowed frontend origins
# -------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# -------------------------------------------------------------------------
# Database (Aiven PostgreSQL)
# -------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# -------------------------------------------------------------------------
# Cloudflare R2 (S3-compatible storage)
# Leave blank to use local filesystem storage (development only).
# -------------------------------------------------------------------------
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=docuconversion
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com

# -------------------------------------------------------------------------
# Authentication (NextAuth.js JWT validation)
# -------------------------------------------------------------------------
NEXTAUTH_SECRET=
AUTH_ENABLED=false

# -------------------------------------------------------------------------
# AI (Google Gemini) — Phase 3
# -------------------------------------------------------------------------
GEMINI_API_KEY=

# -------------------------------------------------------------------------
# Stripe payment integration
# -------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# -------------------------------------------------------------------------
# Shareable links
# -------------------------------------------------------------------------
SHARE_LINK_BASE_URL=http://localhost:3000/share
SHARE_LINK_MAX_TTL_HOURS=72

# -------------------------------------------------------------------------
# Logging
# -------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json   # "json" for production, "text" for local dev

# -------------------------------------------------------------------------
# Sentry error monitoring
# -------------------------------------------------------------------------
SENTRY_DSN=https://your_dsn@sentry.io/project
SENTRY_TRACES_SAMPLE_RATE=0.1
